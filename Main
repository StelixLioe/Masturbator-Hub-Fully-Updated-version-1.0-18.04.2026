--[[
    AdminUILib v2.1
    Полностью рабочий аналог Peallib для админ-панели.
    API: Library:CreateWindow, Window:AddTab, Tab:AddLeftGroupbox, Tab:AddRightGroupbox,
        Groupbox:AddToggle, AddSlider, AddDropdown, AddButton.
    Значения: _G.Toggles.Имя.Value (bool), _G.Options.Имя.Value (number/string)
]]--

local AdminUILib = {}

-- Сервисы
local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local player = Players.LocalPlayer
if not player then Players:GetPropertyChangedSignal("LocalPlayer"):Wait(); player = Players.LocalPlayer end
local playerGui = player:WaitForChild("PlayerGui", 30)

-- Тема
local THEME = {
    accent  = Color3.fromRGB(100,150,255),
    bg      = Color3.fromRGB(16,18,28),
    panel   = Color3.fromRGB(22,24,36),
    header  = Color3.fromRGB(28,30,44),
    text    = Color3.fromRGB(235,238,245),
    muted   = Color3.fromRGB(168,175,190),
    success = Color3.fromRGB(20,200,120),
    danger  = Color3.fromRGB(230,70,70),
    warn    = Color3.fromRGB(255,170,60),
}

-- Глобальные хранилища значений
_G.Toggles = {}
_G.Options = {}

-- Утилиты UI
local function stroke(parent, thickness, color, transparency)
    local s = Instance.new("UIStroke")
    s.Thickness = thickness or 1
    s.Color = color or THEME.accent
    s.Transparency = transparency ~= nil and transparency or 0.35
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = parent
    return s
end

local function rounded(parent, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 10)
    c.Parent = parent
    return c
end

local function applyHover(target, propsIn, propsOut)
    if not target or not target:IsA("GuiObject") then return end
    if target:IsA("TextButton") or target:IsA("ImageButton") then target.AutoButtonColor = false end
    target.MouseEnter:Connect(function()
        TweenService:Create(target, TweenInfo.new(0.15), propsIn):Play()
    end)
    target.MouseLeave:Connect(function()
        TweenService:Create(target, TweenInfo.new(0.15), propsOut):Play()
    end)
end

-- Уведомления
local statusGui = Instance.new("ScreenGui")
statusGui.Name = "AdminUILib_Notifications"
statusGui.ResetOnSpawn = false
statusGui.Parent = playerGui

local function notify(message, icon, duration)
    local yOffset = 10
    for _, child in ipairs(statusGui:GetChildren()) do
        if child.Name == "Note" and child.Visible then yOffset = yOffset + 68 end
    end
    local frame = Instance.new("Frame")
    frame.Name = "Note"
    frame.Size = UDim2.new(0, 320, 0, 60)
    frame.Position = UDim2.new(1, 360, 0, yOffset)
    frame.BackgroundColor3 = THEME.panel
    frame.BackgroundTransparency = 0.1
    frame.BorderSizePixel = 0
    frame.Parent = statusGui
    rounded(frame, 10)
    stroke(frame, 1, THEME.accent, 0.5)
    local glass = Instance.new("Frame")
    glass.Size = UDim2.new(1, 0, 1, 0)
    glass.BackgroundColor3 = Color3.new(1,1,1)
    glass.BackgroundTransparency = 0.92
    glass.BorderSizePixel = 0
    glass.Parent = frame
    rounded(glass, 10)
    local iconLbl = Instance.new("TextLabel")
    iconLbl.Size = UDim2.new(0, 36, 0, 36)
    iconLbl.Position = UDim2.new(0, 12, 0.5, -18)
    iconLbl.BackgroundColor3 = THEME.accent
    iconLbl.BackgroundTransparency = 0.15
    iconLbl.Text = icon or "!"
    iconLbl.TextColor3 = Color3.new(1,1,1)
    iconLbl.Font = Enum.Font.GothamBold
    iconLbl.TextSize = 18
    iconLbl.BorderSizePixel = 0
    iconLbl.Parent = frame
    rounded(iconLbl, 6)
    local msg = Instance.new("TextLabel")
    msg.BackgroundTransparency = 1
    msg.Position = UDim2.new(0, 60, 0, 8)
    msg.Size = UDim2.new(1, -70, 1, -16)
    msg.Text = message or "Status"
    msg.TextColor3 = THEME.text
    msg.TextXAlignment = Enum.TextXAlignment.Left
    msg.TextYAlignment = Enum.TextYAlignment.Center
    msg.Font = Enum.Font.Gotham
    msg.TextSize = 14
    msg.TextWrapped = true
    msg.Parent = frame
    TweenService:Create(frame, TweenInfo.new(0.25), { Position = UDim2.new(1, -340, 0, yOffset) }):Play()
    task.delay(duration or 3, function()
        if frame and frame.Parent then
            TweenService:Create(frame, TweenInfo.new(0.25), { Position = UDim2.new(1, 360, 0, frame.Position.Y.Offset), BackgroundTransparency = 1 }):Play()
            task.wait(0.25)
            frame:Destroy()
        end
    end)
end

-- Элементы управления -------------------------------------------------

local ToggleElement = {}
ToggleElement.__index = ToggleElement
function ToggleElement.new(parent, id, opts)
    local self = setmetatable({}, ToggleElement)
    self.Id = id
    self.Text = opts.Text or id
    self.Default = opts.Default or false
    self.Value = self.Default
    self.OnChanged = opts.OnChanged
    
    self.Container = Instance.new("Frame")
    self.Container.Size = UDim2.new(1, 0, 0, 32)
    self.Container.BackgroundTransparency = 1
    self.Container.Parent = parent
    
    local label = Instance.new("TextLabel")
    label.Text = self.Text
    label.TextColor3 = THEME.text
    label.Font = Enum.Font.Gotham
    label.TextSize = 13
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Size = UDim2.new(1, -50, 1, 0)
    label.BackgroundTransparency = 1
    label.Parent = self.Container
    
    local toggleBtn = Instance.new("TextButton")
    toggleBtn.Size = UDim2.fromOffset(40, 22)
    toggleBtn.Position = UDim2.new(1, -44, 0.5, -11)
    toggleBtn.BackgroundColor3 = self.Default and THEME.success or THEME.muted
    toggleBtn.BorderSizePixel = 0
    toggleBtn.Parent = self.Container
    rounded(toggleBtn, 12)
    
    local dot = Instance.new("Frame")
    dot.Size = UDim2.fromOffset(18, 18)
    dot.Position = self.Default and UDim2.fromOffset(20, 2) or UDim2.fromOffset(2, 2)
    dot.BackgroundColor3 = Color3.new(1,1,1)
    dot.BorderSizePixel = 0
    dot.Parent = toggleBtn
    rounded(dot, 9)
    
    local function update(value)
        self.Value = value
        _G.Toggles[id] = { Value = value }
        local targetPos = value and UDim2.fromOffset(20, 2) or UDim2.fromOffset(2, 2)
        local targetColor = value and THEME.success or THEME.muted
        TweenService:Create(dot, TweenInfo.new(0.12), { Position = targetPos }):Play()
        TweenService:Create(toggleBtn, TweenInfo.new(0.12), { BackgroundColor3 = targetColor }):Play()
        if self.OnChanged then self.OnChanged(value) end
    end
    
    toggleBtn.MouseButton1Click:Connect(function() update(not self.Value) end)
    update(self.Default)
    return self
end

local SliderElement = {}
SliderElement.__index = SliderElement
function SliderElement.new(parent, id, opts)
    local self = setmetatable({}, SliderElement)
    self.Id = id
    self.Text = opts.Text or id
    self.Min = opts.Min or 0
    self.Max = opts.Max or 100
    self.Default = opts.Default or self.Min
    self.Value = self.Default
    self.OnChanged = opts.OnChanged
    
    self.Container = Instance.new("Frame")
    self.Container.Size = UDim2.new(1, 0, 0, 48)
    self.Container.BackgroundTransparency = 1
    self.Container.Parent = parent
    
    local label = Instance.new("TextLabel")
    label.Text = self.Text
    label.TextColor3 = THEME.text
    label.Font = Enum.Font.Gotham
    label.TextSize = 13
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Size = UDim2.new(1, -60, 0, 20)
    label.BackgroundTransparency = 1
    label.Parent = self.Container
    
    local valueLabel = Instance.new("TextLabel")
    valueLabel.Text = tostring(self.Default)
    valueLabel.TextColor3 = THEME.accent
    valueLabel.Font = Enum.Font.GothamBold
    valueLabel.TextSize = 12
    valueLabel.TextXAlignment = Enum.TextXAlignment.Right
    valueLabel.Size = UDim2.new(1, -10, 0, 20)
    valueLabel.BackgroundTransparency = 1
    valueLabel.Parent = self.Container
    
    local sliderBg = Instance.new("Frame")
    sliderBg.Size = UDim2.new(1, 0, 0, 4)
    sliderBg.Position = UDim2.new(0, 0, 0, 28)
    sliderBg.BackgroundColor3 = THEME.muted
    sliderBg.BackgroundTransparency = 0.5
    sliderBg.BorderSizePixel = 0
    sliderBg.Parent = self.Container
    rounded(sliderBg, 2)
    
    local sliderFill = Instance.new("Frame")
    local ratio = (self.Default - self.Min) / (self.Max - self.Min)
    sliderFill.Size = UDim2.new(ratio, 0, 1, 0)
    sliderFill.BackgroundColor3 = THEME.accent
    sliderFill.BorderSizePixel = 0
    sliderFill.Parent = sliderBg
    rounded(sliderFill, 2)
    
    local dragBtn = Instance.new("TextButton")
    dragBtn.Size = UDim2.fromOffset(12, 12)
    dragBtn.Position = UDim2.new(ratio, -6, 0.5, -6)
    dragBtn.BackgroundColor3 = THEME.accent
    dragBtn.BorderSizePixel = 0
    dragBtn.Parent = sliderBg
    rounded(dragBtn, 6)
    
    local dragging = false
    local conn, releaseConn
    dragBtn.MouseButton1Down:Connect(function()
        dragging = true
        local startX = UserInputService:GetMouseLocation().X
        local startScale = dragBtn.Position.X.Scale
        conn = RunService.RenderStepped:Connect(function()
            if not dragging then if conn then conn:Disconnect() end return end
            local delta = (UserInputService:GetMouseLocation().X - startX) / sliderBg.AbsoluteSize.X
            local newScale = math.clamp(startScale + delta, 0, 1)
            local newValue = math.floor(self.Min + (self.Max - self.Min) * newScale)
            self.Value = newValue
            valueLabel.Text = tostring(newValue)
            sliderFill.Size = UDim2.new(newScale, 0, 1, 0)
            dragBtn.Position = UDim2.new(newScale, -6, 0.5, -6)
            _G.Options[id] = { Value = newValue }
            if self.OnChanged then self.OnChanged(newValue) end
        end)
        releaseConn = UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
                if conn then conn:Disconnect() end
                if releaseConn then releaseConn:Disconnect() end
            end
        end)
    end)
    
    _G.Options[id] = { Value = self.Value }
    return self
end

local DropdownElement = {}
DropdownElement.__index = DropdownElement
function DropdownElement.new(parent, id, opts)
    local self = setmetatable({}, DropdownElement)
    self.Id = id
    self.Text = opts.Text or id
    self.Values = opts.Values or {}
    self.DefaultIndex = opts.Default or 1
    self.Value = self.Values[self.DefaultIndex] or self.Values[1]
    self.OnChanged = opts.OnChanged
    
    self.Container = Instance.new("Frame")
    self.Container.Size = UDim2.new(1, 0, 0, 32)
    self.Container.BackgroundTransparency = 1
    self.Container.Parent = parent
    
    local label = Instance.new("TextLabel")
    label.Text = self.Text
    label.TextColor3 = THEME.text
    label.Font = Enum.Font.Gotham
    label.TextSize = 13
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Size = UDim2.new(1, -100, 1, 0)
    label.BackgroundTransparency = 1
    label.Parent = self.Container
    
    local dropdownBtn = Instance.new("TextButton")
    dropdownBtn.Size = UDim2.fromOffset(90, 26)
    dropdownBtn.Position = UDim2.new(1, -94, 0.5, -13)
    dropdownBtn.BackgroundColor3 = THEME.header
    dropdownBtn.BackgroundTransparency = 0.2
    dropdownBtn.Text = self.Value
    dropdownBtn.TextColor3 = THEME.text
    dropdownBtn.Font = Enum.Font.Gotham
    dropdownBtn.TextSize = 12
    dropdownBtn.Parent = self.Container
    rounded(dropdownBtn, 6)
    stroke(dropdownBtn, 1, THEME.accent, 0.5)
    
    local function update(value)
        self.Value = value
        dropdownBtn.Text = value
        _G.Options[id] = { Value = value }
        if self.OnChanged then self.OnChanged(value) end
    end
    
    dropdownBtn.MouseButton1Click:Connect(function()
        local menu = Instance.new("Frame")
        menu.Size = UDim2.fromOffset(120, #self.Values * 28)
        menu.BackgroundColor3 = THEME.panel
        menu.BorderSizePixel = 0
        menu.Parent = self.Container
        rounded(menu, 6)
        stroke(menu, 1, THEME.accent, 0.5)
        local list = Instance.new("UIListLayout", menu)
        list.Padding = UDim.new(0, 2)
        for i, v in ipairs(self.Values) do
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, -4, 0, 26)
            btn.Position = UDim2.new(0, 2, 0, 2 + (i-1)*28)
            btn.BackgroundColor3 = THEME.header
            btn.BackgroundTransparency = 0.3
            btn.Text = v
            btn.TextColor3 = THEME.text
            btn.Font = Enum.Font.Gotham
            btn.TextSize = 12
            btn.Parent = menu
            rounded(btn, 4)
            btn.MouseButton1Click:Connect(function()
                update(v)
                menu:Destroy()
            end)
        end
        task.delay(5, function() if menu then menu:Destroy() end end)
        local closeConn
        closeConn = UserInputService.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                local mousePos = UserInputService:GetMouseLocation()
                local menuPos = menu.AbsolutePosition
                local menuSize = menu.AbsoluteSize
                if not (mousePos.X >= menuPos.X and mousePos.X <= menuPos.X+menuSize.X and mousePos.Y >= menuPos.Y and mousePos.Y <= menuPos.Y+menuSize.Y) then
                    menu:Destroy()
                    closeConn:Disconnect()
                end
            end
        end)
    end)
    
    _G.Options[id] = { Value = self.Value }
    return self
end

local ButtonElement = {}
ButtonElement.__index = ButtonElement
function ButtonElement.new(parent, opts)
    local self = setmetatable({}, ButtonElement)
    self.Text = opts.Text or "Button"
    self.Callback = opts.Callback or function() end
    
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -20, 0, 30)
    btn.Position = UDim2.new(0, 10, 0, 0)
    btn.BackgroundColor3 = THEME.accent
    btn.BackgroundTransparency = 0.2
    btn.Text = self.Text
    btn.TextColor3 = THEME.text
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 12
    btn.Parent = parent
    rounded(btn, 8)
    stroke(btn, 1, THEME.accent, 0.6)
    applyHover(btn, { BackgroundTransparency = 0.1 }, { BackgroundTransparency = 0.2 })
    btn.MouseButton1Click:Connect(self.Callback)
    return self
end

-- Groupbox ------------------------------------------------------------
local Groupbox = {}
Groupbox.__index = Groupbox

function Groupbox.new(parent, title, side)
    local self = setmetatable({}, Groupbox)
    self.Frame = Instance.new("Frame")
    if side == "Right" then
        self.Frame.Size = UDim2.new(0.5, -10, 1, 0)
        self.Frame.Position = UDim2.new(0.5, 10, 0, 0)
    else
        self.Frame.Size = UDim2.new(0.5, -10, 1, 0)
        self.Frame.Position = UDim2.new(0, 0, 0, 0)
    end
    self.Frame.BackgroundColor3 = THEME.header
    self.Frame.BackgroundTransparency = 0.15
    self.Frame.BorderSizePixel = 0
    self.Frame.Parent = parent
    rounded(self.Frame, 10)
    stroke(self.Frame, 1, THEME.accent, 0.5)
    
    local titleLabel = Instance.new("TextLabel")
    titleLabel.Text = title
    titleLabel.TextColor3 = THEME.text
    titleLabel.Font = Enum.Font.GothamBold
    titleLabel.TextSize = 14
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.Size = UDim2.new(1, -24, 0, 24)
    titleLabel.Position = UDim2.new(0, 12, 0, 8)
    titleLabel.BackgroundTransparency = 1
    titleLabel.Parent = self.Frame
    
    self.Content = Instance.new("ScrollingFrame")
    self.Content.Size = UDim2.new(1, -12, 1, -44)
    self.Content.Position = UDim2.new(0, 6, 0, 38)
    self.Content.BackgroundTransparency = 1
    self.Content.BorderSizePixel = 0
    self.Content.ScrollBarThickness = 4
    self.Content.ScrollBarImageColor3 = THEME.accent
    self.Content.ScrollBarImageTransparency = 0.5
    self.Content.CanvasSize = UDim2.new(0, 0, 0, 0)
    self.Content.Parent = self.Frame
    
    self.ListLayout = Instance.new("UIListLayout")
    self.ListLayout.Padding = UDim.new(0, 6)
    self.ListLayout.SortOrder = Enum.SortOrder.LayoutOrder
    self.ListLayout.Parent = self.Content
    
    self.ListLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        self.Content.CanvasSize = UDim2.new(0, 0, 0, self.ListLayout.AbsoluteContentSize.Y + 10)
    end)
    
    self.Elements = {}
    return self
end

function Groupbox:AddToggle(id, opts)
    local elem = ToggleElement.new(self.Content, id, opts)
    table.insert(self.Elements, elem)
    return elem
end

function Groupbox:AddSlider(id, opts)
    local elem = SliderElement.new(self.Content, id, opts)
    table.insert(self.Elements, elem)
    return elem
end

function Groupbox:AddDropdown(id, opts)
    local elem = DropdownElement.new(self.Content, id, opts)
    table.insert(self.Elements, elem)
    return elem
end

function Groupbox:AddButton(opts)
    local elem = ButtonElement.new(self.Content, opts)
    table.insert(self.Elements, elem)
    return elem
end

-- Tab -----------------------------------------------------------------
local Tab = {}
Tab.__index = Tab

function Tab.new(parent, name)
    local self = setmetatable({}, Tab)
    self.Name = name
    self.Frame = Instance.new("Frame")
    self.Frame.Size = UDim2.new(1, 0, 1, 0)
    self.Frame.BackgroundTransparency = 1
    self.Frame.Visible = false
    self.Frame.Parent = parent
    return self
end

function Tab:AddLeftGroupbox(title)
    local gb = Groupbox.new(self.Frame, title, "Left")
    self.LeftGroupbox = gb
    return gb
end

function Tab:AddRightGroupbox(title)
    local gb = Groupbox.new(self.Frame, title, "Right")
    self.RightGroupbox = gb
    return gb
end

function Tab:Show()
    self.Frame.Visible = true
end

function Tab:Hide()
    self.Frame.Visible = false
end

-- Window --------------------------------------------------------------
local Window = {}
Window.__index = Window

function Window.new(opts)
    local self = setmetatable({}, Window)
    self.Title = opts.Title or "Window"
    self.Center = opts.Center == nil and true or opts.Center
    self.AutoShow = opts.AutoShow or false
    
    self.Gui = Instance.new("ScreenGui")
    self.Gui.Name = "AdminUILib_Window"
    self.Gui.ResetOnSpawn = false
    self.Gui.Parent = playerGui
    
    self.MainFrame = Instance.new("Frame")
    self.MainFrame.Size = UDim2.fromOffset(700, 500)
    if self.Center then
        self.MainFrame.Position = UDim2.new(0.5, -350, 0.5, -250)
    else
        self.MainFrame.Position = UDim2.new(0, 0, 0, 0)
    end
    self.MainFrame.BackgroundColor3 = THEME.bg
    self.MainFrame.BackgroundTransparency = 0.05
    self.MainFrame.BorderSizePixel = 0
    self.MainFrame.Parent = self.Gui
    rounded(self.MainFrame, 12)
    stroke(self.MainFrame, 2, THEME.accent, 0.3)
    
    -- Title bar
    local titleBar = Instance.new("Frame")
    titleBar.Size = UDim2.new(1, 0, 0, 48)
    titleBar.BackgroundColor3 = THEME.header
    titleBar.BackgroundTransparency = 0.1
    titleBar.BorderSizePixel = 0
    titleBar.Parent = self.MainFrame
    rounded(titleBar, 12)
    
    local titleLabel = Instance.new("TextLabel")
    titleLabel.Text = self.Title
    titleLabel.TextColor3 = THEME.text
    titleLabel.Font = Enum.Font.GothamBold
    titleLabel.TextSize = 16
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.Size = UDim2.new(1, -50, 1, 0)
    titleLabel.Position = UDim2.new(0, 15, 0, 0)
    titleLabel.BackgroundTransparency = 1
    titleLabel.Parent = titleBar
    
    local closeBtn = Instance.new("TextButton")
    closeBtn.Text = "X"
    closeBtn.TextColor3 = THEME.text
    closeBtn.Font = Enum.Font.GothamBold
    closeBtn.TextSize = 14
    closeBtn.Size = UDim2.fromOffset(30, 30)
    closeBtn.Position = UDim2.new(1, -40, 0.5, -15)
    closeBtn.BackgroundColor3 = THEME.danger
    closeBtn.BackgroundTransparency = 0.2
    closeBtn.BorderSizePixel = 0
    closeBtn.Parent = titleBar
    rounded(closeBtn, 8)
    closeBtn.MouseButton1Click:Connect(function() self.Gui:Destroy() end)
    
    -- Tab bar
    self.TabBar = Instance.new("Frame")
    self.TabBar.Size = UDim2.new(1, -20, 0, 32)
    self.TabBar.Position = UDim2.new(0, 10, 0, 58)
    self.TabBar.BackgroundTransparency = 1
    self.TabBar.Parent = self.MainFrame
    
    -- Content container
    self.ContentContainer = Instance.new("Frame")
    self.ContentContainer.Size = UDim2.new(1, -20, 1, -100)
    self.ContentContainer.Position = UDim2.new(0, 10, 0, 98)
    self.ContentContainer.BackgroundTransparency = 1
    self.ContentContainer.Parent = self.MainFrame
    
    self.Tabs = {}
    self.TabButtons = {}
    return self
end

function Window:AddTab(name)
    local tab = Tab.new(self.ContentContainer, name)
    table.insert(self.Tabs, tab)
    
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.fromOffset(100, 28)
    btn.BackgroundColor3 = THEME.header
    btn.BackgroundTransparency = 0.3
    btn.Text = name
    btn.TextColor3 = THEME.text
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 12
    btn.Parent = self.TabBar
    rounded(btn, 6)
    stroke(btn, 1, THEME.accent, 0.5)
    applyHover(btn, { BackgroundTransparency = 0.15 }, { BackgroundTransparency = 0.3 })
    
    local function select()
        for _, t in ipairs(self.Tabs) do t:Hide() end
        tab:Show()
        for _, b in ipairs(self.TabButtons) do
            b.BackgroundColor3 = THEME.header
            b.BackgroundTransparency = 0.3
        end
        btn.BackgroundColor3 = THEME.accent
        btn.BackgroundTransparency = 0.2
    end
    btn.MouseButton1Click:Connect(select)
    table.insert(self.TabButtons, btn)
    
    if #self.Tabs == 1 then select() end
    
    -- Layout for tab buttons
    local layout = self.TabBar:FindFirstChildOfClass("UIListLayout")
    if not layout then
        layout = Instance.new("UIListLayout")
        layout.FillDirection = Enum.FillDirection.Horizontal
        layout.Padding = UDim.new(0, 6)
        layout.Parent = self.TabBar
    end
    
    return tab
end

function Window:Show()
    if self.Gui then self.Gui.Enabled = true end
end

function Window:Hide()
    if self.Gui then self.Gui.Enabled = false end
end

function Window:Destroy()
    if self.Gui then self.Gui:Destroy() end
end

-- Основная библиотека -------------------------------------------------
function AdminUILib:CreateWindow(opts)
    return Window.new(opts)
end

function AdminUILib:Notify(msg, icon, dur)
    notify(msg, icon, dur)
end

-- Глобальный доступ
_G.Library = AdminUILib

notify("AdminUILib v2.1 loaded. Use Library:CreateWindow()", "✅", 3)

return AdminUILib
